generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionStatus {
  PENDING_INTENT
  AWAITING_APPROVAL
  APPROVED
  COMPLETING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id                   String            @id @default(cuid())
  paymentIntentId      String            @unique
  piPaymentId          String?           @unique
  pioneerUid           String
  bookingReference     String
  amount               Decimal           @db.Decimal(18, 7)
  memo                 String
  metadata             Json
  txid                 String?           @unique
  status               TransactionStatus @default(PENDING_INTENT)
  developerApproved    Boolean           @default(false)
  transactionVerified  Boolean           @default(false)
  developerCompleted   Boolean           @default(false)
  cancelled            Boolean           @default(false)
  pioneerCancelled     Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([pioneerUid, status])
  @@index([bookingReference])
}

model RefreshTokenSession {
  id                String   @id @default(cuid())
  pioneerUid        String
  refreshTokenHash  String
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([pioneerUid])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  resourceId String?
  actorId    String?
  ip         String?
  userAgent  String?
  requestId  String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
}
